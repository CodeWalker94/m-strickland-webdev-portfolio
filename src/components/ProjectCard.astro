---
import type { Project } from '../data/projects';
import { TECH_COLORS } from '../data/techStack';
const { project } = Astro.props as { project: Project };
---

<a class="project-card reveal" href={`/projects/${project.slug}`}>
  {project.screenshots?.[0] ? (
    <div class="project-card-image">
      <img src={project.screenshots[0].src} alt={`${project.title} screenshot`} loading="lazy" />
    </div>
  ) : null}

  <div class="project-card-content">
    <p class="project-tag">Featured project</p>
    <h3>{project.title}</h3>
    <p>{project.description}</p>
    <div class="project-stack">
      {project.stack.map((tech) => (
        <span class="tech-pill" style={`--pill-color: ${TECH_COLORS[tech]}`}>{tech}</span>
      ))}
    </div>
    <div class="project-meta">
      <span>{project.role}</span>
      <span>{project.tech.join(' • ')}</span>
    </div>
  </div>
  <span class="project-cta">View details →</span>
</a>

<style>
.project-card {
  display: grid;
  gap: 1rem;
  padding: 1.5rem;
  border: 1px solid rgba(148, 163, 184, 0.25);
  border-radius: 1.25rem;
  text-decoration: none;
  color: inherit;
  background: rgba(255, 255, 255, 0.9);
  transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
}
.project-card-image {
  overflow: hidden;
  border-radius: 1rem;
  aspect-ratio: 16 / 9;
  background: #eef2ff;
}
.project-card-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: top center;
  display: block;
}
.project-card:hover,
.project-card:focus-visible {
  transform: translateY(-3px);
  border-color: rgba(148, 163, 184, 0.45);
  box-shadow: 0 20px 40px rgba(15, 23, 42, 0.08);
}
.project-tag {
  font-size: 0.8rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: #2563eb;
  margin-bottom: 0.5rem;
}
.project-card h3 {
  margin: 0;
  font-size: 1.35rem;
}
.project-card p {
  margin: 0.75rem 0 0;
  color: #475569;
  line-height: 1.7;
}
.project-stack {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-top: 0.75rem;
}
.tech-pill {
  display: inline-flex;
  align-items: center;
  padding: 0.25rem 0.75rem;
  border-radius: 999px;
  border: 1px solid var(--pill-color);
  color: var(--pill-color);
  background: transparent;
  font-size: 0.75rem;
  font-weight: 600;
}
.project-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
  margin-top: 1rem;
  color: #334155;
  font-size: 0.95rem;
}
.project-cta {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 2.5rem;
  font-weight: 700;
  color: #0f172a;
}
</style>
